#!/usr/bin/env bash
# repo-city-review-loop — run review cycles until campaign completes.
#
# Usage:  ./repo-city-review-loop
#
# Optional env overrides:
#   REPO_CITY_REVIEW_MAX_CYCLES=80
#   REPO_CITY_REVIEW_CYCLE_DELAY=10
#   REPO_CITY_REVIEW_MAX_STALLED=4
#   REPO_CITY_REVIEW_MODE=review_only   (auto by default)
#   REPO_CITY_REVIEW_DRY_RUN=true       (default)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="${SCRIPT_DIR}"

cd "${REPO_ROOT}"

if [[ -f "${REPO_ROOT}/.env" ]]; then
    echo "[repo-city-review-loop] Loading .env"
    set -o allexport
    # shellcheck source=/dev/null
    source "${REPO_ROOT}/.env"
    set +o allexport
fi

export REPO_CITY_REPO_ROOT="${REPO_ROOT}"

PYTHON_BIN="${PYTHON_BIN:-python3}"

if ! command -v "${PYTHON_BIN}" &>/dev/null; then
    echo "ERROR: python3 not found." >&2; exit 1
fi

if ! "${PYTHON_BIN}" -c 'import openai' &>/dev/null; then
    echo "ERROR: openai package not installed. Run: pip install openai" >&2; exit 1
fi

echo "[repo-city-review-loop] Starting autonomous review loop — repo root: ${REPO_ROOT}"
echo "[repo-city-review-loop] Dry run: ${REPO_CITY_REVIEW_DRY_RUN:-true}"
exec "${PYTHON_BIN}" -m agent.review_loop "$@"
