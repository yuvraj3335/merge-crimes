#!/usr/bin/env bash
# repo-city-review-supervised — self-healing review loop.
#
# Wraps the review loop with LLM-assisted repair: when the loop stops
# unexpectedly, the supervisor reads the failure context, asks OpenAI to
# diagnose the cause, applies tracker fixes, and restarts automatically.
#
# Usage:  ./repo-city-review-supervised
#
# Optional env overrides:
#   REPO_CITY_REVIEW_DRY_RUN=false          (default: true — set false to commit fixes)
#   REPO_CITY_REVIEW_MAX_CYCLES=200
#   REPO_CITY_REVIEW_MAX_REPAIRS=5          (default: 5 — max LLM repair attempts)
#   REPO_CITY_REVIEW_CYCLE_DELAY=10
#   REPO_CITY_REVIEW_MAX_STALLED=4
#   REPO_CITY_REVIEW_MODE=review_only       (auto by default)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="${SCRIPT_DIR}"

cd "${REPO_ROOT}"

if [[ -f "${REPO_ROOT}/.env" ]]; then
    echo "[repo-city-review-supervised] Loading .env"
    set -o allexport
    # shellcheck source=/dev/null
    source "${REPO_ROOT}/.env"
    set +o allexport
fi

export REPO_CITY_REPO_ROOT="${REPO_ROOT}"

PYTHON_BIN="${PYTHON_BIN:-python3}"

if ! command -v "${PYTHON_BIN}" &>/dev/null; then
    echo "ERROR: python3 not found." >&2; exit 1
fi

if ! "${PYTHON_BIN}" -c 'import openai' &>/dev/null; then
    echo "ERROR: openai package not installed. Run: pip install openai" >&2; exit 1
fi

echo "[repo-city-review-supervised] Starting self-healing review loop — repo root: ${REPO_ROOT}"
echo "[repo-city-review-supervised] Dry run:        ${REPO_CITY_REVIEW_DRY_RUN:-true}"
echo "[repo-city-review-supervised] Max repairs:    ${REPO_CITY_REVIEW_MAX_REPAIRS:-5}"
exec "${PYTHON_BIN}" -m agent.review_supervisor "$@"
