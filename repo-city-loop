#!/usr/bin/env bash
# repo-city-loop — run repo-city-cycle repeatedly until all phases complete.
#
# Usage:
#   ./repo-city-loop
#
# Optional env overrides:
#   REPO_CITY_MAX_CYCLES=60
#   REPO_CITY_CYCLE_DELAY_SECONDS=10
#   REPO_CITY_MAX_STALLED_CYCLES=3

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="${SCRIPT_DIR}"

cd "${REPO_ROOT}"

if [[ -f "${REPO_ROOT}/.env" ]]; then
    echo "[repo-city-loop] Loading .env"
    set -o allexport
    # shellcheck source=/dev/null
    source "${REPO_ROOT}/.env"
    set +o allexport
fi

export REPO_CITY_REPO_ROOT="${REPO_ROOT}"

PYTHON_BIN="${PYTHON_BIN:-python3}"

if ! command -v "${PYTHON_BIN}" &>/dev/null; then
    echo "ERROR: python3 not found." >&2; exit 1
fi

if ! "${PYTHON_BIN}" -c 'import openai' &>/dev/null; then
    echo "ERROR: openai package not installed. Run: pip install openai" >&2; exit 1
fi

echo "[repo-city-loop] Starting autonomous loop — repo root: ${REPO_ROOT}"
exec "${PYTHON_BIN}" -m agent.repo_city_loop "$@"
